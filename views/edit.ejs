<%- include('partials/header', { title: 'Edit User' }) %>

  <div class="page-header animate-in delay-1">
    <h1 class="page-header__title">Edit Profile</h1>
    <p class="page-header__subtitle">Update details for <%= user.name %></p>
  </div>

  <div class="glass-card form-card animate-in delay-2">
    <form action="/update/<%= user._id %>" method="post" class="form-group">
      <div class="input-wrapper">
        <span class="input-wrapper__icon">👤</span>
        <input
          type="text"
          name="name"
          placeholder="Full name"
          value="<%= user.name %>"
          required
          class="form-input"
        />
      </div>
      <div class="input-wrapper">
        <span class="input-wrapper__icon">✉</span>
        <input
          type="email"
          name="email"
          placeholder="Email address"
          value="<%= user.email %>"
          required
          class="form-input"
        />
      </div>
      <div class="input-wrapper">
        <span class="input-wrapper__icon">🖼</span>
        <input
          type="url"
          name="image"
          placeholder="Profile image URL (optional)"
          value="<%= user.image %>"
          class="form-input"
        />
      </div>
      <button type="submit" class="btn btn--primary" style="margin-top: 6px;">
        Save Changes →
      </button>
    </form>
  </div>

<%- include('partials/footer') %>