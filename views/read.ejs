<%- include('partials/header', { title: 'All Users' }) %>

  <div class="page-header animate-in delay-1">
    <h1 class="page-header__title">All Profiles</h1>
    <p class="page-header__subtitle"><%= users.length %> user<%= users.length !== 1 ? 's' : '' %> saved</p>
  </div>

  <% if (users.length > 0) { %>
    <div class="users-grid">
      <% users.forEach(function(user, i) { %>
        <div class="glass-card user-card animate-in delay-<%= Math.min(i + 2, 8) %>">
          <div class="user-card__image-wrapper">
            <% if (user.image) { %>
              <img class="user-card__image" src="<%= user.image %>" alt="<%= user.name %>" />
            <% } else { %>
              <div class="user-card__avatar-placeholder">👤</div>
            <% } %>
          </div>
          <div class="user-card__body">
            <h3 class="user-card__name"><%= user.name %></h3>
            <p class="user-card__email"><%= user.email %></p>
            <div class="user-card__actions">
              <a href="/edit/<%= user._id %>" class="btn btn--ghost btn--sm">✎ Edit</a>
              <a href="/delete/<%= user._id %>" class="btn btn--danger btn--sm">✕ Delete</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state animate-in delay-2">
      <div class="empty-state__icon">📭</div>
      <p class="empty-state__text">No profiles yet. Start by creating one!</p>
      <a href="/" class="btn btn--primary">Create First Profile →</a>
    </div>
  <% } %>

<%- include('partials/footer') %>